classDiagram
    class Task {
        +str activity
        +int duration
        +str priority
        +str preferences
        +str status
        +mark_complete() None
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +list~Task~ tasks
        +add_task(task) None
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet) None
        +get_all_tasks() dict
    }

    class Schedule {
        +Owner owner
        +list~Pet~ pets
        +list~Task~ tasks
        +print_plan() None
        +get_reasoning() str
    }

    Owner "1" o-- "1..*" Pet : owns
    Pet "1" o-- "0..*" Task : has
    Schedule "1" --> "1" Owner : schedules for
    Schedule "1" --> "1..*" Pet : pools tasks from
    Schedule "1" o-- "0..*" Task : contains
